page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #eef3f8;
}

.page-container {
  flex: 1;
}

.feedback-container {
  min-height: 100%;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(54, 79, 110, 0.08);
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #233142;
}

.summary-block {
  margin-bottom: 24rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #f4f8fc;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-row + .summary-row {
  margin-top: 14rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #6a7788;
}

.summary-value {
  font-size: 28rpx;
  color: #233142;
  font-weight: 600;
}

.summary-money {
  color: #ff6a00;
}

.form-group {
  margin-bottom: 22rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #415163;
}

.form-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 1rpx solid #d7e3ef;
  background: #f7fafc;
  font-size: 28rpx;
  color: #213042;
}

.notice-block {
  margin-bottom: 20rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #fff7e8;
  color: #b26b00;
  font-size: 26rpx;
  line-height: 1.6;
}

.primary-btn,
.action-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #1f8df3;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-btn[disabled] {
  background: #b8c7d8;
  color: #fff;
}

.list-block {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.feedback-item {
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #f7fafc;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #233142;
}

.item-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6a7788;
}

.item-content {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #304255;
  word-break: break-all;
}

.review-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.review-item {
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #fff;
}

.review-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #6a7788;
}

.item-time {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #98a4b2;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 48rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-tag.small {
  min-width: 0;
  height: 40rpx;
  padding: 0 14rpx;
  font-size: 22rpx;
}

.status-pending {
  background: #eef3f8;
  color: #5f6b7a;
}

.status-processing {
  background: #e8f3ff;
  color: #1f8df3;
}

.status-approved {
  background: #e8f8ef;
  color: #1d8f54;
}

.status-rejected {
  background: #ffecec;
  color: #d64c4c;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
}

.action-btn-ghost {
  background: #edf3f9;
  color: #4f5f72;
}

.empty-text {
  font-size: 26rpx;
  color: #7b8898;
  text-align: center;
  padding: 12rpx 0;
}
