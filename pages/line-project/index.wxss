.page-container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(102, 182, 255, 0.14), transparent 34%),
    linear-gradient(180deg, #f6f8ff 0%, #eef6f1 100%);
}

.line-project-page {
  padding: 24rpx 20rpx 40rpx;
}

.workspace-card,
.month-card,
.summary-card {
  margin-bottom: 20rpx;
}

.workspace-card {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 251, 255, 0.98) 100%);
  box-shadow: 0 18rpx 40rpx rgba(40, 84, 120, 0.08);
}

.workspace-main {
  margin-bottom: 24rpx;
}

.workspace-title {
  font-size: 42rpx;
  line-height: 1.2;
  color: #102033;
  font-weight: 700;
}

.workspace-subtitle {
  margin-top: 12rpx;
  font-size: 27rpx;
  color: #0f766e;
  font-weight: 600;
}

.workspace-meta {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #6b7280;
}

.workspace-actions,
.action-row,
.summary-stats {
  display: flex;
}

.workspace-actions,
.action-row,
.summary-stats {
  gap: 18rpx;
}

.workspace-btn,
.half-btn {
  flex: 1;
}

.workspace-btn {
  height: 76rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #1f2937;
  border: 1rpx solid #d7e4ef;
  box-shadow: 0 10rpx 20rpx rgba(15, 118, 110, 0.06);
}

.ghost-btn {
  background: #f8fbff;
  color: #334155;
}

.workspace-admin {
  margin-top: 18rpx;
}

.admin-import-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.month-picker {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 2rpx solid #e8eef6;
  font-size: 30rpx;
  color: #111827;
}

.month-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.summary-card {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0f5f7b 0%, #13808b 48%, #20a58f 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 36rpx rgba(19, 128, 139, 0.18);
}

.summary-label,
.summary-stat-label,
.summary-stat-value {
  color: #ffffff;
}

.summary-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.summary-amount {
  margin-top: 14rpx;
  font-size: 60rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #ffffff;
}

.summary-formula {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(8rpx);
}

.summary-formula-title {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.92);
}

.summary-formula-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 16rpx;
}

.summary-formula-item {
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
}

.summary-formula-item-active {
  background: rgba(255, 255, 255, 0.2);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.3);
}

.summary-formula-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.summary-formula-value {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.summary-stats {
  margin-top: 28rpx;
}

.summary-stat {
  flex: 1;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(8rpx);
}

.summary-stat-value {
  font-size: 34rpx;
  font-weight: 700;
}

.summary-stat-label {
  margin-top: 6rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.action-row {
  margin-top: 8rpx;
}

.summary-action-row {
  margin-top: 24rpx;
}

.half-btn {
  height: 84rpx;
}

.feedback-entry-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #123249;
  border: none;
}

.feedback-entry-btn::after {
  border: none;
}

.mini-btn {
  min-width: 120rpx;
  padding: 0 24rpx;
}

.empty-text {
  padding: 20rpx 0;
  font-size: 25rpx;
  color: #9ca3af;
}

@media (max-width: 540px) {
  .summary-formula-grid,
  .summary-stats,
  .action-row {
    grid-template-columns: 1fr;
  }

  .summary-stats,
  .action-row {
    flex-direction: column;
  }
}
