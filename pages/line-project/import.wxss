.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f9ff 0%, #eef5f0 100%);
}

.line-project-page {
  padding: 20rpx;
}

.filter-grid,
.stats-grid,
.action-row {
  display: grid;
  gap: 20rpx;
}

.filter-grid,
.stats-grid {
  grid-template-columns: 1fr 1fr;
}

.single-grid {
  grid-template-columns: 1fr;
}

.filter-item,
.stats-tile,
.mini-item,
.file-panel,
.empty-panel {
  border-radius: 16rpx;
}

.filter-item {
  background: #f8fafc;
  border: 2rpx solid #e8eef6;
  padding: 22rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.filter-value {
  font-size: 28rpx;
  color: #111827;
}

.tip-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.stats-tile {
  padding: 24rpx;
  background: linear-gradient(135deg, #22577a 0%, #38a3a5 100%);
  color: #fff;
}

.stats-tile .stats-number,
.stats-tile .stats-label {
  color: #fff;
}

.stats-tile .money {
  font-size: 34rpx;
}

.action-row {
  grid-template-columns: 1fr 1fr;
}

.half-btn {
  width: 100%;
  height: 88rpx;
}

.full-btn {
  width: 100%;
}

.file-panel,
.empty-panel {
  background: #f8fafc;
  padding: 24rpx;
}

.file-name {
  font-size: 28rpx;
  color: #111827;
  word-break: break-all;
}

.file-meta,
.mini-sub,
.plain-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.top-gap {
  margin-top: 20rpx;
}

.section-block {
  margin-top: 28rpx;
}

.section-title {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.warning-text {
  color: #b45309;
}

.mini-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mini-item {
  background: #f8fafc;
  padding: 20rpx;
}

.warning-item {
  background: #fff7ed;
}

.mini-title {
  font-size: 28rpx;
  color: #111827;
  word-break: break-all;
}

.card-content,
.empty-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #9ca3af;
}

.empty-text {
  padding: 20rpx 0;
  text-align: center;
}

@media (max-width: 540px) {
  .stats-grid,
  .action-row {
    grid-template-columns: 1fr;
  }
}
