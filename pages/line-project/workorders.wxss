.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f9ff 0%, #eef5f0 100%);
}

.line-project-page {
  padding: 20rpx;
}

.filter-grid,
.overview-grid,
.overview-hero-grid {
  display: grid;
  gap: 20rpx;
}

.filter-grid {
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
}

.overview-grid {
  grid-template-columns: repeat(3, 1fr);
}

.overview-hero-grid {
  grid-template-columns: 1fr;
  margin-bottom: 20rpx;
}

.filter-item,
.overview-tile,
.group-card {
  background: #f8fafc;
  border: 2rpx solid #e8eef6;
  border-radius: 18rpx;
  padding: 22rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.filter-value,
.filter-input {
  font-size: 28rpx;
  color: #111827;
}

.filter-input {
  min-height: 40rpx;
}

.overview-tile {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 144rpx;
}

.overview-amount-tile {
  min-height: 200rpx;
}

.primary-tile {
  background: linear-gradient(135deg, #0f5f7b 0%, #13808b 48%, #20a58f 100%);
  border: none;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f766e;
}

.overview-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.primary-tile .overview-value,
.primary-tile .overview-label {
  color: #ffffff;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #102033;
}

.group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.group-head-main {
  flex: 1;
}

.group-summary {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.group-toggle {
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 600;
}

.group-items {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.compact-group-items {
  margin-top: 12rpx;
}

.group-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 8rpx 0;
  border-top: 1rpx solid #edf2f7;
}

.group-item:first-child {
  border-top: none;
  padding-top: 0;
}

.group-item-name {
  flex: 1;
  font-size: 23rpx;
  line-height: 1.5;
  color: #334155;
}

.group-item-value {
  font-size: 23rpx;
  color: #0f766e;
  font-weight: 600;
  white-space: nowrap;
}

.group-item-active .group-item-name {
  color: #102033;
  font-weight: 600;
}

.list-block {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.item-main {
  flex: 1;
}

.item-code {
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 600;
  word-break: break-all;
}

.item-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  color: #111827;
  word-break: break-all;
}

.item-sub,
.item-side-sub,
.detail-line,
.detail-code {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.item-side {
  min-width: 150rpx;
  text-align: right;
}

.item-value {
  font-size: 30rpx;
  color: #0f766e;
  font-weight: 700;
}

.mini-btn {
  height: 60rpx;
  min-width: 120rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
}

.empty-text,
.load-text {
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
  padding: 24rpx 0;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  z-index: 99;
}

.modal-panel {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.modal-title {
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
}

.modal-close {
  font-size: 40rpx;
  color: #6b7280;
}

.modal-scroll {
  max-height: calc(85vh - 90rpx);
  padding: 28rpx 30rpx;
}

.detail-summary {
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  margin-bottom: 20rpx;
}

@media (max-width: 540px) {
  .filter-grid,
  .overview-hero-grid,
  .overview-grid {
    grid-template-columns: 1fr;
  }

  .list-item {
    flex-direction: column;
  }

  .item-side {
    min-width: 0;
    width: 100%;
    text-align: left;
  }
}
