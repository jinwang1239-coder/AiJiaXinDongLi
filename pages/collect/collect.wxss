/* pages/collect/collect.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f8f8f8;
}

.page-container {
  flex: 1;
  overflow-y: hidden;
}

.collect-container {
  padding: 20rpx 30rpx 40rpx;
  min-height: 100%;
  box-sizing: border-box;
}

/* 批量导入区域 */
.import-card {
  margin-bottom: 30rpx;
}

.import-tips {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.import-file {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #dce6ff;
  border-radius: 8rpx;
  background: #f7f9ff;
}

.import-file-name {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.import-file-clear {
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #667eea;
}

.import-actions {
  display: flex;
  gap: 20rpx;
}

.import-btn {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
}

.import-result {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.import-result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.import-result-summary {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.import-errors {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.import-error-item {
  padding: 16rpx;
  border-radius: 8rpx;
  background: #fff5f5;
  border: 2rpx solid #ffd4d4;
}

.import-error-row {
  font-size: 25rpx;
  font-weight: 600;
  color: #d4380d;
  margin-bottom: 8rpx;
}

.import-error-text {
  font-size: 24rpx;
  color: #8c3a2b;
  line-height: 1.5;
}

/* 表单卡片 */
.form-card {
  margin-bottom: 40rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.commission-preview {
  font-size: 26rpx;
  color: #666;
}

.commission-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
}

/* 表单组 */
.form-group {
  margin-bottom: 35rpx;
}

.form-label {
  display: block;
  margin-bottom: 15rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.form-input,
.form-picker {
  width: 100%;
  border: 2rpx solid #e6e6e6;
  border-radius: 8rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
}

.form-input {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 25rpx;
}

.form-input-placeholder {
  color: #999;
  font-size: 28rpx;
}

.form-picker {
  min-height: 88rpx;
  padding: 25rpx;
  display: flex;
  align-items: center;
}

.form-input:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.form-picker {
  justify-content: space-between;
  margin-bottom: 0;
}

.form-picker::after {
  content: '';
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 12rpx solid #999;
  margin-left: 10rpx;
}

/* 三级联动选择器样式 */
.cascade-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cascade-item {
  width: 100%;
}

.cascade-item .form-picker {
  background: #fff;
  border: 2rpx solid #e6e6e6;
}

.cascade-item.active .form-picker {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

/* 修复长文本显示问题 */
.form-picker text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.placeholder {
  color: #999;
}

/* 图片上传 */
.image-upload-container {
  margin-top: 15rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.image-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.image-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.3);
}

.image-upload-btn {
  width: 150rpx;
  height: 150rpx;
  border: 3rpx dashed #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  transition: all 0.3s ease;
}

.image-upload-btn:active {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

.upload-icon {
  font-size: 40rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 22rpx;
  color: #999;
}

.upload-tips {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 30rpx;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.reset-btn, .submit-btn {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
}
