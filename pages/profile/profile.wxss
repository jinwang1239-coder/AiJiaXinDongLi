page {
  min-height: 100vh;
  background: #f5f7ff;
}

.page-container {
  height: 100vh;
}

.profile-page {
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(77, 96, 169, 0.08);
}

.profile-summary {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
}

.summary-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

.role-tag {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4c63d2;
  font-size: 24rpx;
}

.section-title {
  margin-bottom: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #444;
  font-weight: 600;
}

.form-input,
.picker-field {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f6f8ff;
  border: 1rpx solid #dbe3ff;
  font-size: 28rpx;
  color: #222;
  display: flex;
  align-items: center;
}

.placeholder {
  color: #999;
}

.save-btn {
  margin-top: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #5d73e7 0%, #6f57d9 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}
