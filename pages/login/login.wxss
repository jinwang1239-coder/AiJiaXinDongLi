/* pages/login/login.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.page-container {
  flex: 1;
  overflow-y: hidden;
}

.login-container {
  min-height: 100%;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 未登录状态样式 */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.app-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
}

.app-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 15rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.app-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.login-actions {
  width: 100%;
  max-width: 600rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 60rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.2);
}

.login-tips {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 40rpx;
  backdrop-filter: blur(10rpx);
}

.login-tips > text {
  display: block;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 30rpx;
  text-align: center;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 15rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.tip-item:last-child {
  border-bottom: none;
}

/* 已登录状态样式 */
.user-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 用户信息卡片 */
.user-info-card {
  background: linear-gradient(135deg, #fff 0%, #f8f9ff 100%);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 15rpx;
}

.user-role {
  margin-bottom: 10rpx;
}

.btn-logout {
  padding: 15rpx 30rpx;
  background: rgba(250, 112, 154, 0.1);
  color: #fa709a;
  border: 2rpx solid #fa709a;
  border-radius: 25rpx;
  font-size: 24rpx;
}

/* 统计数据卡片 */
.stats-card {
  overflow: hidden;
}

.btn-detail {
  padding: 10rpx 20rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  border: 1rpx solid #667eea;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  margin: 30rpx 0;
}

.stats-item {
  text-align: center;
  padding: 25rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
}

.stats-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
}

.stats-summary {
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.summary-value.highlight {
  color: #667eea;
  font-size: 32rpx;
}

/* 快捷操作卡片 */
.actions-card .card-title {
  margin-bottom: 30rpx;
}

.action-buttons {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 35rpx 20rpx;
  min-height: 140rpx;
}

.btn-icon {
  font-size: 48rpx;
  margin-bottom: 15rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

/* 权限说明卡片 */
.permission-card {
  margin-bottom: 40rpx;
}

.permission-text {
  padding: 25rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
  border-radius: 12rpx;
  border-left: 6rpx solid #667eea;
}

.permission-text text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
