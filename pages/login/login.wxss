page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #eef3f8;
}

.page-container {
  flex: 1;
}

.login-container {
  min-height: 100%;
  padding: 28rpx;
  box-sizing: border-box;
}

.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.login-header {
  text-align: center;
  margin-bottom: 72rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #5f6b7a;
  line-height: 1.7;
}

.login-actions {
  width: 100%;
  max-width: 640rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  margin-bottom: 36rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #1d84f2 0%, #18b9ef 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.login-tips {
  padding: 32rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(54, 79, 110, 0.08);
}

.login-tips > text {
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #2f3b4d;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #66768a;
}

.user-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.user-card,
.salary-card,
.detail-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(54, 79, 110, 0.08);
}

.user-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 24rpx;
}

.user-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: #dfe7f3;
  flex-shrink: 0;
}

.user-content {
  flex: 1;
  min-width: 0;
}

.user-line {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2d3d;
  margin-bottom: 8rpx;
}

.user-subtitle {
  font-size: 28rpx;
  color: #6a7788;
  line-height: 1.4;
  word-break: break-all;
}

.user-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8c99aa;
}

.user-tools {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tool-btn {
  min-width: 112rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background: #1f8df3;
  color: #fff;
}

.tool-btn-ghost {
  background: #edf3f9;
  color: #4f5f72;
}

.salary-card {
  overflow: hidden;
}

.salary-banner {
  padding: 28rpx 24rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(90deg, #1682f1 0%, #18b8ef 100%);
}

.salary-body {
  padding: 36rpx 30rpx 30rpx;
  background: linear-gradient(180deg, #edf7ff 0%, #f8fbff 100%);
}

.salary-amount {
  font-size: 78rpx;
  line-height: 1;
  font-weight: 800;
  color: #ff6a00;
  text-align: center;
}

.salary-note {
  margin-top: 22rpx;
  text-align: center;
  font-size: 28rpx;
  color: #566579;
}

.detail-card {
  padding: 28rpx 24rpx;
}

.detail-header {
  margin-bottom: 22rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #233142;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.detail-item {
  padding: 22rpx 18rpx;
  border-radius: 18rpx;
  background: #f4f8fc;
}

.detail-label {
  font-size: 24rpx;
  color: #718095;
  margin-bottom: 10rpx;
}

.detail-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #243447;
}

.detail-money {
  color: #ff6a00;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 24, 38, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  box-sizing: border-box;
  z-index: 999;
}

.modal-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #203040;
}

.modal-close {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 26rpx;
  background: #eef3f8;
  color: #607081;
  font-size: 34rpx;
}

.form-group {
  margin-bottom: 22rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #415163;
}

.form-input,
.picker-field {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 1rpx solid #d7e3ef;
  background: #f7fafc;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #213042;
}

.placeholder {
  color: #98a4b2;
}

.submit-btn {
  margin-top: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #1d84f2 0%, #18b9ef 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}