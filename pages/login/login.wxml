<!--pages/login/login.wxml-->
<navigation-bar title="业务收集系统" back="{{false}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="page-container" scroll-y type="list">
  <view class="login-container">
    <view wx:if="{{!hasUserInfo}}" class="login-section">
      <view class="login-header">
        <view class="app-subtitle">便捷的业务信息收集和酬金管理平台</view>
      </view>

      <view class="login-actions">
        <button class="btn btn-primary login-btn" bindtap="onLogin" loading="{{loading}}">
          <text wx:if="{{!loading}}">微信授权登录</text>
          <text wx:else>登录中...</text>
        </button>

        <view class="login-tips">
          <text>首次登录后需补充个人信息</text>
          <view class="tips-list">
            <view class="tip-item">填写姓名和网格通账号</view>
            <view class="tip-item">按区县和网格名称完成所属网格选择</view>
            <view class="tip-item">保存后可在个人信息页自行修改</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="user-section">
      <view class="user-card">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-content">
          <view class="user-line">姓名：{{profileDisplayName}}</view>
          <view class="user-subtitle">{{profileSubtitle}}</view>
        </view>
        <view class="user-tools">
          <button class="tool-btn" bindtap="openProfileModal">编辑个人信息</button>
          <button class="tool-btn tool-btn-ghost" bindtap="onLogout">退出登录</button>
        </view>
      </view>

      <view class="salary-card">
        <view class="salary-banner">{{monthLabel}} 当月总酬金</view>
        <view class="salary-body">
          <view class="salary-amount">¥{{stats.monthCommission}}</view>
          <view class="salary-note">本月共完成 {{stats.monthRecords}} 笔业务</view>
        </view>
      </view>

      <view class="detail-card">
        <view class="detail-header">业务量与酬金明细</view>
        <view class="detail-grid">
          <view class="detail-item">
            <view class="detail-label">今日业务量</view>
            <view class="detail-value">{{stats.todayRecords}} 笔</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">今日酬金</view>
            <view class="detail-value detail-money">¥{{stats.todayCommission}}</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">本月业务量</view>
            <view class="detail-value">{{stats.monthRecords}} 笔</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">本月酬金</view>
            <view class="detail-value detail-money">¥{{stats.monthCommission}}</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">累计业务量</view>
            <view class="detail-value">{{stats.totalRecords}} 笔</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">累计酬金</view>
            <view class="detail-value detail-money">¥{{stats.totalCommission}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<view wx:if="{{showProfileModal}}" class="modal-mask" bindtap="closeProfileModal">
  <view class="modal-panel" catchtap="stopModalPropagation">
    <view class="modal-header">
      <view class="modal-title">补充个人信息</view>
      <view class="modal-close" bindtap="closeProfileModal">×</view>
    </view>

    <view class="form-group">
      <view class="form-label">姓名</view>
      <input class="form-input" placeholder="请输入姓名" value="{{profileForm.realName}}" data-field="realName" bindinput="onProfileInputChange" />
    </view>

    <view class="form-group">
      <view class="form-label">网格通账号</view>
      <input class="form-input" placeholder="请输入网格通账号" value="{{profileForm.gridAccount}}" data-field="gridAccount" bindinput="onProfileInputChange" />
    </view>

    <view class="form-group">
      <view class="form-label">区县</view>
      <picker range="{{districts}}" bindchange="onDistrictChange">
        <view class="picker-field {{profileForm.district ? '' : 'placeholder'}}">{{profileForm.district || '请选择区县'}}</view>
      </picker>
    </view>

    <view class="form-group">
      <view class="form-label">所属网格</view>
      <picker range="{{grids}}" bindchange="onGridChange" disabled="{{!profileForm.district}}">
        <view class="picker-field {{profileForm.gridName ? '' : 'placeholder'}}">{{profileForm.gridName || '请选择所属网格'}}</view>
      </picker>
    </view>

    <button class="submit-btn" bindtap="submitProfile" loading="{{savingProfile}}">保存个人信息</button>
  </view>
</view>
